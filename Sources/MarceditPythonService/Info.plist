<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.marclaw.Marcedit.PythonService</string>
    <key>CFBundleName</key>
    <string>MarceditPythonService</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>XPCService</key>
    <dict>
        <key>ServiceType</key>
        <string>Application</string>
    </dict>
    <!--
        AppTeamID is read at runtime by main.swift to tighten the XPC
        code-signing requirement to the development team's OU.
        When added to the Xcode project, set this to $(DEVELOPMENT_TEAM)
        via the "User-Defined" build setting so Xcode substitutes the real
        team identifier at build/signing time.
    -->
    <key>AppTeamID</key>
    <string>$(DEVELOPMENT_TEAM)</string>
</dict>
</plist>
